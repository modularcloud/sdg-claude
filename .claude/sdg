#!/usr/bin/env bash
# sdg — narrow reviewer-only helper for Spec-Driven Generation.

set -euo pipefail

SDG_VERSION="0.3.0"
DEFAULT_SDG_REVIEW_MODEL="gpt-5"
DEFAULT_SDG_REVIEW_EFFORT="high"
DEFAULT_REVIEW_OUT="specs/tmp/REVIEW.md"

SDG_REVIEW_MODEL="${SDG_REVIEW_MODEL:-$DEFAULT_SDG_REVIEW_MODEL}"
SDG_REVIEW_EFFORT="${SDG_REVIEW_EFFORT:-$DEFAULT_SDG_REVIEW_EFFORT}"

die() { printf 'sdg: %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SUMMARY_FILE="${SDG_REVIEW_SUMMARY:-$(script_dir)/reviewer-process-summary.md}"

usage() {
  cat <<'EOF'
usage: sdg <command> [...]

commands:
  review [flags] <spec|test-spec|patch> [patch-path]
  version

review flags:
  --model M       OpenAI model (default: SDG_REVIEW_MODEL or gpt-5)
  --effort E      reasoning effort (default: SDG_REVIEW_EFFORT or high)
  --out P         review output path (default: specs/tmp/REVIEW.md)
  --summary P     reviewer process summary markdown
  --dry-run       print the assembled prompt without calling OpenAI

requirements:
  OPENAI_API_KEY must be set for non-dry-run reviews.
  openai CLI must be installed and on PATH for non-dry-run reviews.
  specs/ must already exist.
  specs/tmp/ is created when missing.
EOF
}

append_text() {
  local bundle="$1" heading="$2" text="$3"
  {
    printf '\n\n## %s\n\n' "$heading"
    printf '%s\n' "$text" | tr -d '\r\000'
  } >> "$bundle"
}

append_file() {
  local bundle="$1" file="$2" heading="${3:-$2}"
  [[ -f "$file" ]] || die "required file missing: $file"
  {
    printf '\n\n## %s\n\n' "$heading"
    tr -d '\r\000' < "$file"
    printf '\n'
  } >> "$bundle"
}

append_optional_file() {
  local bundle="$1" file="$2" heading="${3:-$2}"
  [[ -f "$file" ]] || return 0
  append_file "$bundle" "$file" "$heading"
}

append_module_files() {
  local bundle="$1" test_only="$2"
  [[ -d specs/modules ]] || return 0

  local file base is_test
  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    base="$(basename "$file")"
    is_test=0
    [[ "$base" == TEST-* ]] && is_test=1

    if [[ "$test_only" == "1" && "$is_test" == "1" ]]; then
      append_file "$bundle" "$file"
    elif [[ "$test_only" == "0" && "$is_test" == "0" ]]; then
      append_file "$bundle" "$file"
    fi
  done < <(find specs/modules -maxdepth 1 -type f -name '*.md' 2>/dev/null | LC_ALL=C sort)
}

build_prompt() {
  local target="$1" patch_path="$2" bundle="$3"

  : > "$bundle"
  append_text "$bundle" "Reviewer Instructions" \
    "You are Reviewer for a Spec-Driven Generation workflow. You receive this single prompt, produce one review, retain no memory, and do not edit files."
  append_file "$bundle" "$SUMMARY_FILE" "Reviewer Process Summary"
  append_optional_file "$bundle" PROCESS.md "Root Process"
  append_optional_file "$bundle" specs/PROCESS.md "Specs Process"
  append_optional_file "$bundle" specs/GOALS.md "Goals"
  append_optional_file "$bundle" specs/IMPLEMENTATION.md "Implementation Notes"

  case "$target" in
    spec)
      append_optional_file "$bundle" specs/tmp/SPEC-PROBLEMS.md "Active SPEC Problems"
      append_file "$bundle" specs/SPEC.md "Review Target: specs/SPEC.md"
      append_module_files "$bundle" 0
      ;;
    test-spec)
      append_optional_file "$bundle" specs/SPEC.md "SPEC Context"
      append_module_files "$bundle" 0
      append_optional_file "$bundle" specs/tmp/TEST-SPEC-PROBLEMS.md "Active TEST-SPEC Problems"
      append_file "$bundle" specs/TEST-SPEC.md "Review Target: specs/TEST-SPEC.md"
      append_module_files "$bundle" 1
      ;;
    patch)
      [[ -f "$patch_path" ]] || die "required file missing: $patch_path"
      append_optional_file "$bundle" specs/SPEC.md "SPEC Context"
      append_module_files "$bundle" 0
      append_optional_file "$bundle" specs/TEST-SPEC.md "TEST-SPEC Context"
      append_module_files "$bundle" 1
      append_optional_file "$bundle" specs/tmp/PATCH-PROBLEMS.md "Active PATCH Problems"
      append_file "$bundle" "$patch_path" "Review Target: $patch_path"
      ;;
    *)
      die "unknown review target: $target (want spec, test-spec, or patch)"
      ;;
  esac

  append_text "$bundle" "Final Instruction" \
    "Return the review in the output format from the reviewer process summary. State explicitly whether any critical issues remain."
}

invoke_openai() {
  local bundle="$1" out="$2" req err tmp_out
  req="$(mktemp)"
  err="$(mktemp)"
  tmp_out="$(mktemp)"

  {
    printf 'model: %s\n' "$SDG_REVIEW_MODEL"
    if [[ -n "$SDG_REVIEW_EFFORT" ]]; then
      printf 'reasoning:\n  effort: %s\n' "$SDG_REVIEW_EFFORT"
    fi
    printf 'input: |\n'
    tr -d '\r\000' < "$bundle" | sed 's/^/  /'
  } > "$req"

  if ! openai responses create \
        --format yaml \
        --transform 'output.#(type=="message").content.0.text' \
        --raw-output \
        < "$req" > "$tmp_out" 2> "$err"; then
    cat "$err" >&2
    rm -f "$req" "$err" "$tmp_out"
    die "openai CLI failed"
  fi

  if [[ ! -s "$tmp_out" ]] || ! grep -q '[^[:space:]]' "$tmp_out"; then
    [[ -s "$err" ]] && cat "$err" >&2
    rm -f "$req" "$err" "$tmp_out"
    die "openai CLI returned no review text"
  fi

  mkdir -p "$(dirname "$out")"
  mv "$tmp_out" "$out"
  rm -f "$req" "$err"
}

cmd_review() {
  local out="$DEFAULT_REVIEW_OUT" dry_run=0 target="" patch_path=""

  while (( $# > 0 )); do
    case "$1" in
      --model)
        (( $# >= 2 )) || die "--model requires a value"
        SDG_REVIEW_MODEL="$2"; shift 2 ;;
      --model=*)
        SDG_REVIEW_MODEL="${1#--model=}"; shift ;;
      --effort)
        (( $# >= 2 )) || die "--effort requires a value"
        SDG_REVIEW_EFFORT="$2"; shift 2 ;;
      --effort=*)
        SDG_REVIEW_EFFORT="${1#--effort=}"; shift ;;
      --out)
        (( $# >= 2 )) || die "--out requires a value"
        out="$2"; shift 2 ;;
      --out=*)
        out="${1#--out=}"; shift ;;
      --summary)
        (( $# >= 2 )) || die "--summary requires a value"
        SUMMARY_FILE="$2"; shift 2 ;;
      --summary=*)
        SUMMARY_FILE="${1#--summary=}"; shift ;;
      --dry-run)
        dry_run=1; shift ;;
      -*)
        die "unknown flag: $1" ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        elif [[ -z "$patch_path" ]]; then
          patch_path="$1"
        else
          die "unexpected argument: $1"
        fi
        shift ;;
    esac
  done

  [[ -n "$target" ]] || die "usage: sdg review [flags] <spec|test-spec|patch> [patch-path]"
  if [[ "$target" == "patch" && -z "$patch_path" ]]; then
    die "usage: sdg review [flags] patch <path>"
  fi
  [[ -d specs ]] || die "required directory missing: specs"
  [[ -f "$SUMMARY_FILE" ]] || die "required file missing: $SUMMARY_FILE"
  mkdir -p specs/tmp

  if (( ! dry_run )); then
    [[ -n "${OPENAI_API_KEY:-}" ]] || die "OPENAI_API_KEY is not set"
    have openai || die "openai CLI is not installed or not on PATH"
  fi

  local bundle
  bundle="$(mktemp)"

  build_prompt "$target" "$patch_path" "$bundle"

  if (( dry_run )); then
    cat "$bundle"
    rm -f "$bundle"
    return 0
  fi

  invoke_openai "$bundle" "$out"
  rm -f "$bundle"
  printf 'wrote %s (model=%s effort=%s)\n' "$out" "$SDG_REVIEW_MODEL" "$SDG_REVIEW_EFFORT"
}

main() {
  (( $# >= 1 )) || { usage; exit 2; }
  local cmd="$1"; shift
  case "$cmd" in
    review) cmd_review "$@" ;;
    version|-v|--version) printf 'sdg %s\n' "$SDG_VERSION" ;;
    help|-h|--help) usage ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

main "$@"
